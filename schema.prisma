generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Siswa {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  nama      String
  kelas     String
  createdAt DateTime @default(now())
}

model Guru {
  id        Int      @id @default(autoincrement())
  nip       String   @unique
  nama      String
  mapel     String
  createdAt DateTime @default(now())
}

model Pengumuman {
  id        Int      @id @default(autoincrement())
  judul     String
  isi       String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  aktivitas String
  createdAt DateTime @default(now())
}